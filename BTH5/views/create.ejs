<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo bài viết mới</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <a href="/" class="back-link">← Quay lại trang chủ</a>

        <header>
            <h1>Tạo bài viết mới</h1>
        </header>

        <div class="card">
            <form action="/blogposts/store" method="POST">
                <div class="form-group">
                    <label for="title">Tiêu đề bài viết:</label>
                    <input type="text" id="title" name="title" placeholder="Nhập tiêu đề thật hấp dẫn..." required>
                </div>

                <div class="form-group">
                    <label for="body">Nội dung:</label>
                    <!-- Tăng rows lên 8 cho không gian rộng hơn khi viết bài -->
                    <textarea id="body" name="body" rows="8" placeholder="Viết những suy nghĩ của bạn ở đây..."
                        required></textarea>
                </div>

                <button type="submit" class="btn">Xuất bản bài viết</button>
            </form>
        </div>
    </div>
</body>

</html>