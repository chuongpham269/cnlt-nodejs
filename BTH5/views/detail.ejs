<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= post.title %>
    </title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <a href="/" class="back-link">← Trở về danh sách</a>

        <div class="card" style="padding: 40px;">
            <header style="margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 20px;">
                <h1 style="font-size: 2.5rem; margin-bottom: 10px;">
                    <%= post.title %>
                </h1>
            </header>

            <div style="font-size: 1.1rem; color: var(--text-main); white-space: pre-wrap; line-height: 1.8;">
                <%= post.body %>
            </div>

            <div class="card-actions" style="margin-top: 40px;">
                <a href="/blogposts/edit/<%= post._id %>" class="btn btn-secondary">Chỉnh sửa</a>
                <a href="/blogposts/delete/<%= post._id %>" class="btn btn-delete" onclick="confirmDelete(event)">Xóa
                    bài viết</a>
            </div>
        </div>
    </div>

    <script>
        function confirmDelete(e) {
            if (!confirm('Bạn có chắc chắn muốn xóa bài viết này không?')) {
                e.preventDefault();
            }
        }
    </script>
</body>

</html>