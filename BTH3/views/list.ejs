<%- include('layouts/header') %>
<%- include('layouts/navbar') %>

<div class="row mb-4">
    <div class="col-12">
        <h1 class="text-center"><%= title %></h1>
        <p class="text-center">Có <%= clubs.length %> câu lạc bộ đang hoạt động</p>
    </div>
</div>

<div class="row">
    <% clubs.forEach(club => { %>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100">
                <img src="<%= club.image || 'https://via.placeholder.com/300x200' %>" 
                     class="card-img-top" 
                     alt="<%= club.name %>"
                     style="height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title"><%= club.name %></h5>
                    <p class="card-text"><%= club.description.substring(0, 80) %>...</p>
                    
                    <div class="mb-2">
                        <small class="text-muted">
                            <i class="fas fa-calendar"></i> Thành lập: <%= club.founded %>
                        </small>
                    </div>
                    
                    <div class="mb-2">
                        <small class="text-muted">
                            <i class="fas fa-tag"></i> <%= club.category %>
                        </small>
                    </div>
                    
                    <!-- Sử dụng if/else để hiển thị trạng thái -->
                    <% if(club.hot) { %>
                        <span class="badge bg-danger">
                            <i class="fas fa-fire"></i> Đang nổi bật
                        </span>
                    <% } else { %>
                        <span class="badge bg-secondary">
                            <i class="fas fa-clock"></i> CLB thường
                        </span>
                    <% } %>
                    
                    <div class="mt-2">
                        <i class="fas fa-user-friends"></i> 
                        <%= club.members %> thành viên
                    </div>
                </div>
                <div class="card-footer">
                    <a href="/detail/<%= club.id %>" class="btn btn-primary w-100">
                        Xem chi tiết
                    </a>
                </div>
            </div>
        </div>
    <% }); %>
</div>

<%- include('layouts/footer') %>